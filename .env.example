# Copy to .env and fill in. NEVER commit .env (it's gitignored).
# Find your account identifier in Snowsight: bottom-left account menu -> "Account" -> copy the identifier
# (looks like  ORGNAME-ACCOUNTNAME  e.g.  ab12345.eu-west-1 ).

SNOWFLAKE_ACCOUNT=your_account_identifier
SNOWFLAKE_USER=your_username

# --- Auth (pick ONE) ---
# Key-pair (recommended; REQUIRED if your account enforces MFA). Relative path
# from the repo root, so it stays portable across machines / CI.
SNOWFLAKE_PRIVATE_KEY_PATH=rsa_key.p8
# Password (only works if MFA is NOT enforced). Leave blank when using key-pair.
SNOWFLAKE_PASSWORD=

# Optional — sensible defaults applied if omitted
SNOWFLAKE_ROLE=ACCOUNTADMIN
SNOWFLAKE_WAREHOUSE=COMPUTE_WH
SNOWFLAKE_DATABASE=NYC_TAXI

# Which months to load (comma-separated). Start with one to validate.
MONTHS=2023-01

# dbt model toggle: 'false' skips ALL dbt models (e.g. daily ingestion-only run).
# Unset / 'true' = full build. Read by each model's enabled: in schema.yml.
MODELS_ENABLED=true

# Slack notifications (Airflow). Create an Incoming Webhook and paste its URL.
# If unset, notifications are logged and skipped (won't break local runs).
SLACK_WEBHOOK_URL=
ENVIRONMENT=dev
# Email fallback on failure (optional)
ALERT_EMAIL=data-alerts@example.com
